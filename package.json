{
  "name": "healthbridge",
  "version": "1.0.0",
  "description": "Healthcare clinic booking platform - Monorepo",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter healthbridge-client dev\" \"pnpm --filter healthbridge-server dev\"",
    "client": "pnpm --filter healthbridge-client dev",
    "server": "pnpm --filter healthbridge-server dev",
    "build": "pnpm --filter healthbridge-client build && pnpm --filter healthbridge-server build",
    "db:setup": "pnpm --filter healthbridge-server db:setup",
    "install-all": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "mysql2": "^3.22.3",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10"
  }
}
